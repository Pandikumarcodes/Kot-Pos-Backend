{
  "name": "kot-pos-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node src/seed.js",
    "test:backend": "jest",
    "test:backend:watch": "jest --watch",
    "test:backend:coverage": "jest --coverage",
    "test:backend:ci": "jest --ci --coverage --forceExit",
    "test:e2e": "cross-env E2E_TESTING=true NODE_ENV=test node src/app.js"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": ".",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/src/__tests__/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/routes/**/*.js",
      "src/middlewares/**/*.js",
      "src/utils/**/*.js",
      "!src/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "branches": 65
      }
    },
    "testTimeout": 10000
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pandikumarcodes/Kot-Pos-Backend.git"
  },
  "keywords": [
    "nodejs",
    "Javascript"
  ],
  "author": "\"Pandi kumar\"",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Pandikumarcodes/Kot-Pos-Backend/issues"
  },
  "homepage": "https://github.com/Pandikumarcodes/Kot-Pos-Backend#readme",
  "dependencies": {
    "@google/genai": "^1.50.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "socket.io": "^4.8.3",
    "validator": "^13.15.15",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2"
  }
}
